# ================================
# BENICEFLUTTER - CONFIGURACIÓN
# ================================

# ---------------------------------
# SUPABASE (Requerido)
# ---------------------------------
# Obtén estas credenciales en: https://app.supabase.com
# Proyecto > Settings > API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...

# Service Role Key para operaciones de servidor (webhooks)
# Proyecto > Settings > API > service_role key
# NUNCA exponer esta clave en el frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---------------------------------
# STRIPE - Pagos (Requerido para checkout)
# ---------------------------------
# Obtén las claves en: https://dashboard.stripe.com/apikeys
# Usa claves de test (sk_test_, pk_test_) para desarrollo
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Webhook para confirmar pagos
# Crea en: https://dashboard.stripe.com/webhooks
# Evento: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---------------------------------
# RESEND - Emails transaccionales (Requerido)
# ---------------------------------
# Crea cuenta en: https://resend.com
# API Keys: https://resend.com/api-keys
RESEND_API_KEY=re_xxx

# Email del remitente (debe estar verificado en Resend)
# Para desarrollo puedes usar: onboarding@resend.dev
FROM_EMAIL=ventas@beniceflutter.com

# ---------------------------------
# URL DE LA APLICACIÓN
# ---------------------------------
# URL base para enlaces en emails y deep links
# En producción: https://beniceflutter.victoriafp.online
PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------
# CLOUDINARY - Imágenes de productos
# ---------------------------------
# Obtén las credenciales en: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=dqeoftgqy
CLOUDINARY_API_KEY=599194427753915
CLOUDINARY_API_SECRET=WtsuylA-eGnfcaHRaTtoZIVLYJ0

# ---------------------------------
# GOOGLE PLACES API - Autocompletado de dirección
# ---------------------------------
# Clave secreta de servidor — NUNCA exponer en el frontend.
# Se usa vía backend en Flutter
# Obtén la clave en: https://console.cloud.google.com/apis/credentials
# Asegúrate de activar: Places API (New) 
# Restricciones: por IP de servidor + quota limits
GOOGLE_PLACES_API_KEY=AIza...

# ---------------------------------
# CONFIGURACIÓN FLUTTER ESPECÍFICA
# ---------------------------------
# Entorno de ejecución (development/staging/production)
FLUTTER_ENV=development

# Configuración de base de datos local (opcional para desarrollo)
LOCAL_DB_URL=postgresql://user:password@localhost:5432/benice_flutter

# Claves para servicios de notificación push (opcional)
FCM_SERVER_KEY=AAAAXXX...
